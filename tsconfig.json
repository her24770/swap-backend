{
    "compilerOptions": {
        /* ── Compilación ── */
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        /* ── Rutas ── */
        "rootDir": "./src",
        "outDir": "./dist",
        /* ── Módulos ── */
        "moduleResolution": "node",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        /* ── Calidad de código ── */
        "strict": true,
        "skipLibCheck": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        /* ── Decorators (por si usas en el futuro) ── */
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}