# ─── App ───────────────────────────────────────
NODE_ENV=production
PORT=3001
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRACION=8h  

# ─── PostgreSQL ────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret
POSTGRES_DB=appdb

# Prisma usa esta variable directamente
DATABASE_URL=postgresql://admin:secret@postgres:5432/appdb?schema=public

# ─── Redis ─────────────────────────────────────
REDIS_PASSWORD=redissecret
REDIS_URL=redis://:redissecret@redis:6379   